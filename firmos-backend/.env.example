# firmOS Backend Environment Variables
FIRMOS_AUTH_MODE=dev
DATABASE_URL=your-value-here
SUPABASE_JWT_SECRET=your-value-here
TOKEN_ENC_KEY=your-value-here

# AI / ML — Extraction
GEMINI_API_KEY=your-value-here
SARVAM_API_KEY=your-value-here
EXTRACTOR_TYPE=your-value-here
MODEL_PRIMARY=your-value-here
MODEL_ESCALATE=your-value-here

# Zoho Books OAuth (Required for T1 & T3)
ZOHO_CLIENT_ID=your-value-here
ZOHO_CLIENT_SECRET=your-value-here
ZOHO_REDIRECT_URI=your-value-here
ZOHO_REFRESH_TOKEN=your-value-here
ZOHO_ORGANIZATION_ID=your-value-here

# GSTN GSP/Sandbox Credentials (Required for T3 & T4)
GSTN_CLIENT_ID=your-value-here
GSTN_CLIENT_SECRET=your-value-here
GSTN_USERNAME=your-value-here
GSTN_ENVIRONMENT=your-value-here

REDIS_URL=your-value-here

# WhiteBooks Sandbox
GSP_API_KEY=your-value-here
GSP_API_SECRET=your-value-here
TEST_GSTIN=your-value-here
GST_USERNAME=your-value-here
GSP_BASE_URL=your-value-here
WHITEBOOKS_EMAIL=your-value-here
